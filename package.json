{
  "name": "tableau-mcp-chat",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "python -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 8787",
    "dev:web": "vite",
