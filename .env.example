# IMPORTANT: Use KEY=value lines only. Do not paste MCP_SERVERS JSON here (see mcp-servers.cursor.example.json).

# workbook = dashboards/sheets only (default). datasource = published datasource + query-datasource.
TABLEAU_CHAT_MODE=workbook

# OpenAI (required for the chat page)
OPENAI_API_KEY=sk-your-key-here

# Tableau REST sign-in (same idea as Cursor MCP env: SERVER, SITE_NAME, PAT_NAME, PAT_VALUE)
TABLEAU_SERVER=
# Site "contentUrl" from Tableau (case-sensitive). For the DEFAULT site on Tableau Server, leave empty:
# TABLEAU_SITE_NAME=
TABLEAU_SITE_NAME=
TABLEAU_PAT_NAME=
TABLEAU_PAT_VALUE=

# If you see 401 from /auth/signin: regenerate the PAT on the server, confirm PAT_NAME matches the label
# in My Account → Personal Access Tokens, confirm TABLEAU_SITE_NAME matches the site's content URL
# (not always the same as the display name), and try an empty TABLEAU_SITE_NAME for the default site.

# Optional: MCP client timeouts (ms). SDK default is 60s; Tableau tools often need longer (-32001 if too short).
# MCP_REQUEST_TIMEOUT_MS=900000
# MCP_INIT_TIMEOUT_MS=180000
# MCP_LIST_TOOLS_TIMEOUT_MS=120000

# Tableau MCP: get-datasource-metadata often breaks on VDS (Zod "expression" required on joins).
# This app excludes that tool by default so list-datasources + query-datasource still work.
# Opt back in only if your server returns full join metadata:
# ENABLE_DATASOURCE_METADATA_TOOL=1
# Or set EXCLUDE_TOOLS / INCLUDE_TOOLS yourself (then auto-append of get-datasource-metadata is skipped when INCLUDE_TOOLS is set).

# Optional: extra lines appended to the model system prompt (org-specific metrics / naming)
# CHAT_SYSTEM_EXTRA=Published datasource is named "NOC Performance". After listing fields, use the real date and measure captions in query-datasource (e.g. Report Date, Performance %).

# Optional: self-signed TLS only (insecure; remove in production)
# NODE_TLS_REJECT_UNAUTHORIZED=0
# TABLEAU_SSL_VERIFY=0

# Run: pip install -r requirements.txt && npm install && npm run dev
# UI: http://localhost:5173

# Tableau extension: if API is on a different host than the built UI, set when building:
# VITE_API_BASE=https://api.example.com

# Built-in field lister uses Tableau REST sign-in + Metadata GraphQL (/api/metadata/graphql).
# On Tableau Server, Metadata API must be enabled (see Tableau help). Tableau Cloud: always available.
# TABLEAU_REST_API_VERSION=3.27
# DISABLE_LOCAL_DATASOURCE_FIELD_TOOL=1

# --- If chat says "permissions" / cannot list fields ---
# 1) Server admin: tsm maintenance metadata-services enable  (Tableau Server only)
# 2) PAT user: View on project/datasource; open datasource in Tableau Web to confirm
# 3) Datasource: enable "API Access" (needed for query-datasource, not just listing)
# 4) Use exact name from list-datasources or pass LUID in chat
# 5) Test: http://localhost:5173/api/metadata-check
# 6) Test: http://localhost:5173/api/datasource-fields?name=Budget_vs_Revenue
# Note: API Access on one datasource (Tableau UI) ≠ Metadata API; PAT must be the same user (e.g. MPPLAdmin).
