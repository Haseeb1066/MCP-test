<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.tableau-mcp.chat" extension-version="0.2.5">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description resource-id="description"/>
    <author name="Tableau MCP Chat" email="" website="https://example.com"/>
    <min-api-version>1.0</min-api-version>
    <source-location>
      <url>https://mcp-test-ldxl.onrender.com</url>
    </source-location>
    <icon></icon>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">Tableau MCP Chat</text>
    </resource>
    <resource id="description">
      <text locale="en_US">Ask questions about this workbook using Tableau MCP and OpenAI.</text>
    </resource>
  </resources>
</manifest>
